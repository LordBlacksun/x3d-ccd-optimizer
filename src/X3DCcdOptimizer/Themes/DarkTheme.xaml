<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="BgPrimary">#1A1A1E</Color>
    <Color x:Key="BgSecondary">#232328</Color>
    <Color x:Key="BgTertiary">#2C2C32</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#E8E8ED</Color>
    <Color x:Key="TextSecondary">#9898A0</Color>
    <Color x:Key="TextTertiary">#5C5C66</Color>

    <!-- Accents -->
    <Color x:Key="AccentBlue">#4B9EFF</Color>
    <Color x:Key="AccentGreen">#34C759</Color>
    <Color x:Key="AccentPurple">#9B6DFF</Color>
    <Color x:Key="AccentAmber">#FFB340</Color>
    <Color x:Key="AccentRed">#FF4545</Color>

    <!-- Core tile load colors -->
    <Color x:Key="CoreIdle">#232328</Color>
    <Color x:Key="CoreModerate">#3D3520</Color>
    <Color x:Key="CoreHot">#1E3328</Color>

    <!-- Borders -->
    <Color x:Key="BorderDefault">#3A3A42</Color>
    <Color x:Key="BorderSubtle">#2A2A32</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}"/>

    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
    <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>

    <SolidColorBrush x:Key="CoreIdleBrush" Color="{StaticResource CoreIdle}"/>
    <SolidColorBrush x:Key="CoreModerateBrush" Color="{StaticResource CoreModerate}"/>
    <SolidColorBrush x:Key="CoreHotBrush" Color="{StaticResource CoreHot}"/>

    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>

</ResourceDictionary>
