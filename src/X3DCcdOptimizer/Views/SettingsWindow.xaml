<Window x:Class="X3DCcdOptimizer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — X3D CCD Optimizer"
        Width="580" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        AutomationProperties.Name="Settings window">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="12,12,12,0"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderThickness="0"
                    AutomationProperties.Name="Settings tabs">

            <!-- Tab 1: General -->
            <TabItem Header="General" AutomationProperties.Name="General settings tab">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="4">
                        <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="Launch the optimizer automatically when you log into Windows."
                                  AutomationProperties.Name="Start with Windows checkbox"/>
                        <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="Start hidden in the system tray instead of showing the dashboard."
                                  AutomationProperties.Name="Start minimized checkbox"/>
                        <CheckBox Content="Minimize to tray on close" IsChecked="{Binding MinimizeToTray}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="When enabled, closing the window minimizes to the system tray instead of exiting. Use the tray icon to fully exit."
                                  AutomationProperties.Name="Minimize to tray on close checkbox"/>
                        <CheckBox Content="Show notifications" IsChecked="{Binding Notifications}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="Show system notifications when games are detected or affinities change."
                                  AutomationProperties.Name="Show notifications checkbox"/>

                        <TextBlock Text="{Binding TierDescription}" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="0,8,0,8"/>

                        <TextBlock Text="Default mode on launch:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                        <ComboBox SelectedValue="{Binding DefaultMode}" SelectedValuePath="Content"
                                  Width="140" HorizontalAlignment="Left"
                                  ToolTip="Monitor watches your CPU without making changes. Optimize actively pins games to the best CCD."
                                  AutomationProperties.Name="Default operation mode">
                            <ComboBoxItem Content="monitor"/>
                            <ComboBoxItem Content="optimize" IsEnabled="{Binding CanOptimize}"/>
                        </ComboBox>

                        <TextBlock Text="Optimization strategy:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"
                                   Visibility="{Binding StrategyVisibility}"/>
                        <ComboBox SelectedValue="{Binding OptimizeStrategy}" SelectedValuePath="Tag"
                                  Width="320" HorizontalAlignment="Left"
                                  IsEnabled="{Binding IsStrategyAvailable}"
                                  Visibility="{Binding StrategyVisibility}"
                                  AutomationProperties.Name="Optimization strategy"
                                  ToolTip="Choose how the app manages CCD affinity.">
                            <ComboBoxItem Content="Driver Preference (recommended for X3D)" Tag="driverPreference" IsEnabled="{Binding IsDriverAvailable}"/>
                            <ComboBoxItem Content="Affinity Pinning (advanced)" Tag="affinityPinning"/>
                        </ComboBox>
                        <TextBlock Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding StrategyVisibility}"
                                   Text="Driver Preference uses AMD's 3D V-Cache driver — works with the scheduler. Affinity Pinning hard-pins processes to CCDs — more aggressive, overrides the scheduler."/>
                        <TextBlock Text="Strategy changes take effect on next launch."
                                   Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" Margin="0,2,0,0"
                                   Visibility="{Binding StrategyVisibility}"/>
                        <TextBlock Text="&#x26A0; AMD 3D V-Cache driver not detected. Install AMD chipset drivers or use Affinity Pinning."
                                   Foreground="{StaticResource AccentAmberBrush}" FontSize="11" Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding DriverWarningVisibility}"/>
                        <!-- Affinity Pinning liability warning -->
                        <TextBlock Foreground="{StaticResource AccentAmberBrush}" FontSize="10" TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding AffinityPinningWarningVisibility}"
                                   Text="&#x26A0; Affinity Pinning directly modifies process CPU affinity. Some anti-cheat systems may behave unexpectedly with modified affinity masks. Use at your own risk in competitive online games. The developer assumes no liability for any consequences of using this software."/>
                        <!-- Driver Preference CPPC guidance -->
                        <TextBlock Foreground="{StaticResource TextTertiaryBrush}" FontSize="10" TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding DriverPreferenceCppcVisibility}">
                            <Run Text="Driver Preference works best with CPPC Dynamic Preferred Cores set to 'Driver' in your BIOS (AMD CBS &#x2192; SMU Common Options). This allows the AMD 3D V-Cache driver to manage CCD preference. The 'Auto' BIOS setting may not reliably activate core parking."/>
                            <Run Text=" "/>
                            <Hyperlink NavigateUri="https://github.com/LordBlacksun/x3d-ccd-optimizer/wiki/AMD-X3D-Scheduling-Explained"
                                       RequestNavigate="OnHyperlinkNavigate">See the Wiki for a full explanation.</Hyperlink>
                        </TextBlock>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,4">
                            <Run Text="Polling interval:"/> <Run Text="{Binding PollingIntervalMs, StringFormat={}{0}ms}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="1000" Maximum="5000" Value="{Binding PollingIntervalMs}"
                                TickFrequency="500" IsSnapToTickEnabled="True"
                                ToolTip="How often the app checks for running games."
                                AutomationProperties.Name="Polling interval slider"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Dashboard refresh:"/> <Run Text="{Binding DashboardRefreshMs, StringFormat={}{0}ms}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="500" Maximum="5000" Value="{Binding DashboardRefreshMs}"
                                TickFrequency="500" IsSnapToTickEnabled="True"
                                ToolTip="How often the dashboard updates core load and frequency."
                                AutomationProperties.Name="Dashboard refresh interval slider"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Process Rules (tier-aware) -->
            <TabItem Header="Process Rules" AutomationProperties.Name="Process rules settings tab">
                <Grid Margin="8">

                    <!-- SingleCcdStandard: no process rules available -->
                    <StackPanel Visibility="{Binding SingleCcdStandardVisibility}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Single-CCD processor detected"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Process rules require a dual-CCD processor to manage affinity between CCDs. Game detection is still active for monitoring."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                    </StackPanel>

                    <!-- Dual-CCD and SingleCcdX3D: show game column + conditional bg column -->
                    <Grid Visibility="{Binding GameColumnVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Game column (all tiers except SingleCcdStandard) -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Foreground="{StaticResource AccentGreenBrush}"
                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6">
                                <Run Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                <Run Text="{Binding GameColumnHeader, Mode=OneWay}"/>
                            </TextBlock>

                            <ListBox Grid.Row="1" ItemsSource="{Binding ManualGames}" SelectedItem="{Binding SelectedGame}"
                                     FontFamily="{StaticResource FontMono}" FontSize="11"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ToolTip="{Binding GameColumnTooltip}"
                                     AutomationProperties.Name="Games list"/>

                            <StackPanel Grid.Row="2" Margin="0,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewGameText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="4,2"
                                             ToolTip="Type a game exe or search the known database."
                                             AutomationProperties.Name="New game executable name"/>
                                    <Button Grid.Column="1" Content="Add" Command="{Binding AddGameCommand}" Style="{StaticResource SubtleButtonStyle}"
                                            Margin="4,0,0,0" Padding="8,2" AutomationProperties.Name="Add game"/>
                                </Grid>
                                <ListBox ItemsSource="{Binding GameSuggestions}" MaxHeight="80" FontSize="10"
                                         FontFamily="{StaticResource FontMono}"
                                         Margin="0,2,0,0"
                                         Visibility="{Binding GameSuggestions.Count, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                                         SelectionChanged="OnGameSuggestionSelected"
                                         AutomationProperties.Name="Game autocomplete suggestions"/>
                                <Button Content="Remove" Command="{Binding RemoveGameCommand}" Style="{StaticResource SubtleButtonStyle}"
                                        Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left"
                                        AutomationProperties.Name="Remove selected game"/>
                            </StackPanel>
                        </Grid>

                        <!-- Right: Background column (dual-CCD only) -->
                        <Grid Grid.Column="2" Visibility="{Binding BgColumnVisibility}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Foreground="{StaticResource AccentBlueBrush}"
                                       FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6">
                                <Run Text="&#xE7EE;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                                <Run Text="{Binding BgColumnHeader, Mode=OneWay}"/>
                            </TextBlock>

                            <Grid Grid.Row="1">
                                <ListBox ItemsSource="{Binding BackgroundApps}" SelectedItem="{Binding SelectedBg}"
                                         FontFamily="{StaticResource FontMono}" FontSize="11"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ToolTip="{Binding BgColumnTooltip}"
                                         AutomationProperties.Name="Background apps list"/>
                                <TextBlock Text="No background rules configured. In Optimize mode, unmatched processes are still auto-migrated to the Frequency CCD. Add explicit rules here for guaranteed pinning and clearer activity log tracking."
                                           Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"
                                           TextWrapping="Wrap" Margin="8,8"
                                           VerticalAlignment="Top" IsHitTestVisible="False"
                                           Visibility="{Binding BgEmptyHintVisibility}"/>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,6,0,0">
                                <Button Content="Pick Running Processes..." Command="{Binding AddBgFromPickerCommand}"
                                        Style="{StaticResource SubtleButtonStyle}" Padding="8,5"
                                        HorizontalAlignment="Stretch" FontWeight="SemiBold"
                                        AutomationProperties.Name="Open process picker"/>
                                <Button Content="Remove" Command="{Binding RemoveBgCommand}" Style="{StaticResource SubtleButtonStyle}"
                                        Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Left"
                                        AutomationProperties.Name="Remove selected background app"/>
                            </StackPanel>
                        </Grid>

                        <!-- SingleCcdX3D: info message in place of right column -->
                        <StackPanel Grid.Column="2" Visibility="{Binding SingleCcdX3DVisibility}"
                                    VerticalAlignment="Center" Margin="8">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Single-CCD X3D processor detected. All cores share the V-Cache — no background migration needed. Game detection is active for monitoring."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 3: Detection -->
            <TabItem Header="Detection" AutomationProperties.Name="Detection settings tab">
                <Grid Margin="8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <CheckBox Content="Enable GPU auto-detection" IsChecked="{Binding AutoDetectEnabled}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="Automatically detect games by monitoring GPU usage."
                                  AutomationProperties.Name="Enable GPU auto-detection checkbox"/>
                        <CheckBox Content="Require foreground window" IsChecked="{Binding RequireForeground}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  ToolTip="Only detect a game if it's the active foreground window."
                                  AutomationProperties.Name="Require foreground window checkbox"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="GPU threshold:"/> <Run Text="{Binding GpuThreshold, StringFormat={}{0}%}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="20" Maximum="90" Value="{Binding GpuThreshold}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="GPU threshold slider"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Detection delay:"/> <Run Text="{Binding DetectionDelay, StringFormat={}{0}s}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="1" Maximum="15" Value="{Binding DetectionDelay}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="Detection delay slider"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Exit delay:"/> <Run Text="{Binding ExitDelay, StringFormat={}{0}s}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="5" Maximum="30" Value="{Binding ExitDelay}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="Exit delay slider"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Excluded Processes:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>

                    <ListBox Grid.Row="3" ItemsSource="{Binding ExcludedProcesses}" SelectedItem="{Binding SelectedExclusion}"
                             Background="{StaticResource BgSecondaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderDefaultBrush}"
                             FontFamily="{StaticResource FontMono}" FontSize="11"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ToolTip="Processes that should never be detected as games."
                             AutomationProperties.Name="Excluded processes list"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBox Width="160" Text="{Binding NewExclusionText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderThickness="1" BorderBrush="{StaticResource BorderDefaultBrush}" Padding="4,2"
                                 AutomationProperties.Name="New exclusion process name"/>
                        <Button Content="Add" Command="{Binding AddExclusionCommand}" Style="{StaticResource SubtleButtonStyle}"
                                Margin="4,0,0,0" Padding="8,2" AutomationProperties.Name="Add exclusion"/>
                        <Button Content="Remove" Command="{Binding RemoveExclusionCommand}" Style="{StaticResource SubtleButtonStyle}"
                                Margin="4,0,0,0" Padding="8,2" AutomationProperties.Name="Remove exclusion"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 4: Overlay -->
            <TabItem Header="Overlay" AutomationProperties.Name="Overlay settings tab">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="8,4">
                        <CheckBox Content="Enable overlay" IsChecked="{Binding OverlayEnabled}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  AutomationProperties.Name="Enable overlay checkbox"/>
                        <CheckBox Content="Show CCD load bars" IsChecked="{Binding ShowOverlayBars}"
                                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4"
                                  AutomationProperties.Name="Show CCD load bars checkbox"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Opacity:"/> <Run Text="{Binding OverlayOpacity, StringFormat={}{0:F0}%}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="30" Maximum="100" Value="{Binding OverlayOpacity}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="Overlay opacity slider"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Auto-hide after:"/> <Run Text="{Binding AutoHideSeconds, StringFormat={}{0}s}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="5" Maximum="30" Value="{Binding AutoHideSeconds}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="Auto-hide delay slider"/>

                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4">
                            <Run Text="Pixel shift every:"/> <Run Text="{Binding PixelShiftMinutes, StringFormat={}{0} min}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Slider Minimum="1" Maximum="10" Value="{Binding PixelShiftMinutes}"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                AutomationProperties.Name="Pixel shift interval slider"/>

                        <TextBlock Text="Default position:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                        <ComboBox SelectedValue="{Binding OverlayPosition}" SelectedValuePath="Tag"
                                  Width="160" HorizontalAlignment="Left"
                                  ToolTip="Screen corner for the overlay when not manually dragged."
                                  AutomationProperties.Name="Overlay position selector">
                            <ComboBoxItem Content="Top Left" Tag="TopLeft"/>
                            <ComboBoxItem Content="Top Right" Tag="TopRight"/>
                            <ComboBoxItem Content="Bottom Left" Tag="BottomLeft"/>
                            <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                        </ComboBox>

                        <TextBlock Text="Hotkey: Ctrl+Shift+O" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,12,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 5: Advanced -->
            <TabItem Header="Advanced" AutomationProperties.Name="Advanced settings tab">
                <StackPanel Margin="8,4">
                    <TextBlock Text="Log level:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                    <ComboBox SelectedValue="{Binding LogLevel}" Width="160" HorizontalAlignment="Left"
                              Background="{StaticResource BgTertiaryBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                              AutomationProperties.Name="Log level selector">
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Information"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Error"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Open Log Folder" Command="{Binding OpenLogFolderCommand}"
                                Style="{StaticResource SubtleButtonStyle}" Padding="10,4" Margin="0,0,8,0"
                                AutomationProperties.Name="Open log folder button"/>
                        <Button Content="Open Config Folder" Command="{Binding OpenConfigFolderCommand}"
                                Style="{StaticResource SubtleButtonStyle}" Padding="10,4"
                                AutomationProperties.Name="Open config folder button"/>
                    </StackPanel>

                    <Button Content="Reset All to Defaults" Command="{Binding ResetDefaultsCommand}"
                            Style="{StaticResource SubtleButtonStyle}" Padding="10,4"
                            HorizontalAlignment="Left" Margin="0,16,0,0"
                            AutomationProperties.Name="Reset all settings to defaults button"/>

                    <!-- Disclaimer -->
                    <Border Margin="0,20,0,0" Padding="10" CornerRadius="4"
                            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
                        <TextBlock Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16">
                            <Run FontWeight="SemiBold">DISCLAIMER:</Run>
                            <Run Text="X3D CCD Optimizer modifies CPU affinity and/or AMD driver registry preferences to optimize CCD scheduling. While these are standard Windows and AMD features, the developer provides this software as-is with no warranty. The developer assumes no liability for any consequences including but not limited to: anti-cheat detection, game bans, system instability, or data loss. Use at your own risk. See LICENSE (GPL v2) for full terms."/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- OK / Cancel / Apply -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8,12,12">
            <Button Content="OK" Click="OnOk" Style="{StaticResource SubtleButtonStyle}"
                    Width="80" Margin="0,0,8,0" AutomationProperties.Name="OK button"/>
            <Button Content="Cancel" Click="OnCancel" Style="{StaticResource SubtleButtonStyle}"
                    Width="80" Margin="0,0,8,0" AutomationProperties.Name="Cancel button"/>
            <Button Content="Apply" Click="OnApply" Style="{StaticResource SubtleButtonStyle}"
                    Width="80" AutomationProperties.Name="Apply settings button"/>
        </StackPanel>
    </Grid>
</Window>
