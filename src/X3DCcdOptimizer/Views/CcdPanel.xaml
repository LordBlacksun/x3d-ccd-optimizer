<UserControl x:Class="X3DCcdOptimizer.Views.CcdPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:X3DCcdOptimizer.Views">
    <Border CornerRadius="8"
            Background="{StaticResource BgSecondaryBrush}"
            BorderBrush="{Binding BorderBrush}"
            BorderThickness="{Binding BorderThickness}"
            Padding="12" Margin="4">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,6">
                <TextBlock Text="{Binding CcdName}" Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"/>
                <!-- Badge -->
                <Border Style="{StaticResource BadgeStyle}"
                        Background="{Binding BadgeBackground}">
                    <TextBlock Text="{Binding BadgeText}"
                               Foreground="{Binding BadgeForeground}"
                               FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <!-- L3 size -->
                <TextBlock Text="{Binding L3SizeText}" Style="{StaticResource SmallText}"
                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Core range -->
            <TextBlock Text="{Binding CoreRangeText}" Style="{StaticResource HintText}" Margin="0,0,0,2"/>

            <!-- Role label -->
            <TextBlock Text="{Binding RoleLabel}" Style="{StaticResource SmallText}" Margin="0,0,0,8"/>

            <!-- Core grid -->
            <ItemsControl ItemsSource="{Binding Cores}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="2" Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:CoreTile/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
