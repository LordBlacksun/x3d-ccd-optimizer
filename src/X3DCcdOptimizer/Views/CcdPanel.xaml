<UserControl x:Class="X3DCcdOptimizer.Views.CcdPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:X3DCcdOptimizer.Views">
    <Grid Margin="4,2">
        <!-- Accent left edge — identity stripe (V-Cache=green, Frequency=blue) -->
        <Border CornerRadius="8,0,0,8" Width="3" HorizontalAlignment="Left"
                Background="{Binding BadgeBackground}" Opacity="0.5"/>

        <!-- Main panel -->
        <Border CornerRadius="8"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="{Binding BorderThickness}"
                Padding="12,8" Margin="2,0,0,0">
            <DockPanel>
                <!-- Header row: CCD name, badge, L3 size, core range, role label — all in one line -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="{Binding CcdName}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Border Style="{StaticResource BadgeStyle}"
                            Background="{Binding BadgeBackground}">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="{Binding BadgeForeground}"
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="{Binding L3SizeText}" Style="{StaticResource HintText}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding CoreRangeText}" Style="{StaticResource HintText}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding RoleLabel}" Style="{StaticResource SmallText}"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Core grid — single row, all cores side by side -->
                <ItemsControl ItemsSource="{Binding Cores}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CoreTile/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
