<UserControl x:Class="X3DCcdOptimizer.Views.CcdPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:X3DCcdOptimizer.Views">
    <Grid Margin="4">
        <!-- Accent left edge — identity stripe (V-Cache=green, Frequency=blue) -->
        <Border CornerRadius="8,0,0,8" Width="3" HorizontalAlignment="Left"
                Background="{Binding BadgeBackground}" Opacity="0.5"/>

        <!-- Main panel -->
        <Border CornerRadius="8"
                Background="{StaticResource BgSecondaryBrush}"
                BorderBrush="{Binding BorderBrush}"
                BorderThickness="{Binding BorderThickness}"
                Padding="16,14" Margin="2,0,0,0">
            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding CcdName}" Style="{StaticResource SectionHeader}"
                               VerticalAlignment="Center"/>
                    <!-- Badge -->
                    <Border Style="{StaticResource BadgeStyle}"
                            Background="{Binding BadgeBackground}">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="{Binding BadgeForeground}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <!-- L3 size -->
                    <TextBlock Text="{Binding L3SizeText}" Style="{StaticResource SmallText}"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Core range -->
                <TextBlock Text="{Binding CoreRangeText}" Style="{StaticResource HintText}" Margin="0,0,0,3"/>

                <!-- Role label -->
                <TextBlock Text="{Binding RoleLabel}" Style="{StaticResource SmallText}" Margin="0,0,0,10"/>

                <!-- Core grid -->
                <ItemsControl ItemsSource="{Binding Cores}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="2" Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CoreTile/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
