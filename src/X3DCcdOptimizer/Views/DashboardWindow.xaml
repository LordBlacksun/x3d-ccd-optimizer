<Window x:Class="X3DCcdOptimizer.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:X3DCcdOptimizer.Views"
        Title="X3D Dual CCD Optimizer"
        Width="860" Height="740"
        MinWidth="680" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Status Bar -->
        <Border Grid.Row="0" CornerRadius="8" Margin="12,12,12,0" Padding="12,8"
                Background="{Binding StatusColor}">
            <DockPanel>
                <!-- Mode toggle (right) -->
                <ToggleButton DockPanel.Dock="Right" Style="{StaticResource PillToggleStyle}"
                              IsChecked="{Binding IsOptimizeMode}"
                              IsEnabled="{Binding IsOptimizeEnabled}"
                              Margin="12,0,0,0"/>

                <!-- Session timer -->
                <TextBlock DockPanel.Dock="Right" Text="{Binding SessionDurationText}"
                           Visibility="{Binding SessionVisible}"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0"/>

                <!-- Status text -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="White" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 1: CCD Panels -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="2" Margin="8,4">
            <views:CcdPanel DataContext="{Binding Ccd0Panel}"/>
            <views:CcdPanel DataContext="{Binding Ccd1Panel}"/>
        </UniformGrid>

        <!-- Row 2: Process Router -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Process Router" Style="{StaticResource EmphasisText}"
                           Margin="0,0,0,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ProcessRouter.Processes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ProcessName}"
                                               FontFamily="{StaticResource FontMono}" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                            Background="{Binding BadgeColor}" Margin="8,0">
                                        <TextBlock Text="{Binding CcdBadge}" Foreground="White"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                               Style="{StaticResource SmallText}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Row 3: Activity Log -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Activity Log" Style="{StaticResource EmphasisText}"
                           Margin="0,0,0,6"/>
                <ListBox x:Name="LogListBox"
                         ItemsSource="{Binding ActivityLog.Entries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Opacity="{Binding Opacity}">
                                <TextBlock Text="{Binding Timestamp}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActionText}"
                                           Foreground="{Binding ActionColor}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           FontWeight="SemiBold" FontStyle="{Binding FontStyle}"
                                           Margin="0,0,8,0" VerticalAlignment="Center"
                                           MinWidth="170"/>
                                <TextBlock Text="{Binding DetailText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontStyle="{Binding FontStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Row 4: Footer -->
        <Border Grid.Row="4" Padding="16,6" Margin="0">
            <TextBlock Text="{Binding FooterText}" Style="{StaticResource HintText}"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
