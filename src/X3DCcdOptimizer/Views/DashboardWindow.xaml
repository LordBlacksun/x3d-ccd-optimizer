<Window x:Class="X3DCcdOptimizer.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:X3DCcdOptimizer.Views"
        Title="X3D Dual CCD Optimizer"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        Icon="pack://application:,,,/Resources/app.ico"
        AutomationProperties.Name="X3D CCD Optimizer dashboard">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Status Bar — gradient overlay + pulsing dot -->
        <Border Grid.Row="0" CornerRadius="10" Margin="12,12,12,0" Padding="14,10"
                Background="{Binding StatusColor}">
            <Border.OpacityMask>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Border.OpacityMask>
            <Grid>
                <Border CornerRadius="10" Background="{StaticResource StatusBarOverlay}"
                        IsHitTestVisible="False"/>
                <DockPanel>
                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource PillToggleStyle}"
                                  IsChecked="{Binding IsOptimizeMode}"
                                  IsEnabled="{Binding IsOptimizeEnabled}"
                                  Margin="14,0,0,0"
                                  AutomationProperties.Name="Operation mode toggle"
                                  ToolTip="Toggle between Monitor (observe only) and Optimize (actively pin games to V-Cache CCD)."/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SessionDurationText}"
                               Visibility="{Binding SessionVisible}"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource FontMono}"
                               VerticalAlignment="Center" Margin="14,0" Opacity="0.9"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.35" Duration="0:0:1.2"
                                                             AutoReverse="True">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <!-- Row 1: CCD Panels (compact, 8x1 cores) -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="2" Margin="8,8">
            <views:CcdPanel DataContext="{Binding Ccd0Panel}" AutomationProperties.Name="Primary CCD panel"/>
            <views:CcdPanel DataContext="{Binding Ccd1Panel}" AutomationProperties.Name="Secondary CCD panel"
                            Visibility="{Binding ShowSecondPanel, Converter={StaticResource BoolToVis}}"/>
        </UniformGrid>

        <!-- Row 2: Tabbed lower section (Process Router + Activity Log) -->
        <TabControl Grid.Row="2" Margin="12,4,12,4" SelectedIndex="1"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Dashboard tabs">
            <TabItem Header="Process Router" AutomationProperties.Name="Process Router tab">
                <Border Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="No managed processes"
                                   Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Visibility="{Binding ProcessRouter.EmptyVisibility}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ProcessRouter.ProcessView}">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Padding="6,3" Margin="0,2,0,1"
                                                        BorderThickness="2,0,0,0" BorderBrush="{StaticResource AccentBlueBrush}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text="{Binding ItemCount, StringFormat='({0})', Mode=OneWay}"
                                                             Foreground="{StaticResource TextTertiaryBrush}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4,3" Margin="8,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding ProcessName, Mode=OneWay}"/>
                                                    <Run Text="{Binding CountText, Mode=OneWay}"
                                                         Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                </TextBlock>
                                                <Border Grid.Column="1" CornerRadius="3" Padding="6,1" Margin="6,0"
                                                        Background="{Binding TypeBadgeColor}"
                                                        Visibility="{Binding IsGame, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="GAME" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding ExeName}"
                                                           FontFamily="{StaticResource FontMono}" FontSize="10"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Activity Log" AutomationProperties.Name="Activity Log tab">
                <Border Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                    <ListBox x:Name="LogListBox"
                             ItemsSource="{Binding ActivityLog.Entries}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             AlternationCount="2">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bg" CornerRadius="3" Padding="6,3" Margin="0,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                    <Setter TargetName="Bg" Property="Background"
                                                            Value="{StaticResource RowAltBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Opacity="{Binding Opacity}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="185"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                               FontFamily="{StaticResource FontMono}" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActionText}"
                                               Foreground="{Binding ActionColor}"
                                               FontFamily="{StaticResource FontMono}" FontSize="11"
                                               FontWeight="SemiBold" FontStyle="{Binding FontStyle}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DetailText}"
                                               FontFamily="{StaticResource FontMono}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontStyle="{Binding FontStyle}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Row 3: Footer — separator + info + overlay toggle -->
        <StackPanel Grid.Row="3">
            <Rectangle Height="1" Margin="24,2,24,0"
                       Fill="{StaticResource FooterSeparatorBrush}"/>
            <DockPanel Margin="16,6,16,8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SubtleButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="Settings" FontSize="11" Padding="10,4"
                            AutomationProperties.Name="Open settings window"/>
                    <Button Style="{StaticResource SubtleButtonStyle}"
                            Command="{Binding ToggleOverlayCommand}"
                            Content="{Binding OverlayButtonText}"
                            FontSize="11" Padding="10,4" Margin="6,0,0,0"
                            AutomationProperties.Name="Toggle overlay visibility"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0" Opacity="0.7"
                            ToolTip="Running with administrator privileges"
                            AutomationProperties.Name="Administrator status indicator">
                    <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"
                               Margin="0,0,3,0"/>
                    <TextBlock Text="ADMIN" Foreground="{StaticResource AccentGreenBrush}"
                               FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding FooterText}" Style="{StaticResource HintText}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
