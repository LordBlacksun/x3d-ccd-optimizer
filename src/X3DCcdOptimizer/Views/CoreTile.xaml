<UserControl x:Class="X3DCcdOptimizer.Views.CoreTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CoreTileStyle}"
            Background="{Binding LoadColor}"
            Opacity="{Binding TileOpacity}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Core index -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{Binding CoreLabel}"
                       Style="{StaticResource HintText}"
                       HorizontalAlignment="Left"/>

            <!-- Frequency -->
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding FrequencyText}"
                       Style="{StaticResource HintText}"
                       HorizontalAlignment="Right"/>

            <!-- Load percentage -->
            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding LoadText}"
                       Style="{StaticResource BigNumber}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,2,0,0"/>
        </Grid>
    </Border>
</UserControl>
