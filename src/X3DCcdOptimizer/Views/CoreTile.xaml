<UserControl x:Class="X3DCcdOptimizer.Views.CoreTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CoreTileStyle}"
            Background="{Binding LoadColor}"
            Opacity="{Binding TileOpacity}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Core index (small, top) -->
            <TextBlock Grid.Row="0"
                       Text="{Binding CoreLabel}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="9" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"/>

            <!-- Load percentage (large, center) -->
            <TextBlock Grid.Row="1"
                       Text="{Binding LoadText}"
                       Style="{StaticResource BigNumber}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Frequency (small, below percentage) -->
            <TextBlock Grid.Row="2"
                       Text="{Binding FrequencyText}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="9"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,2"/>

            <!-- Load bar (thin, bottom) -->
            <Border Grid.Row="3"
                    Height="3" CornerRadius="1.5"
                    Background="{StaticResource BorderSubtleBrush}">
                <Border CornerRadius="1.5" HorizontalAlignment="Left"
                        Background="{StaticResource AccentGreenBrush}"
                        Opacity="0.7">
                    <Border.Width>
                        <MultiBinding>
                            <MultiBinding.Converter>
                                <local:LoadBarWidthConverter xmlns:local="clr-namespace:X3DCcdOptimizer.Converters"/>
                            </MultiBinding.Converter>
                            <Binding Path="LoadPercent"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                        </MultiBinding>
                    </Border.Width>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
