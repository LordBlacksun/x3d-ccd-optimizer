<UserControl x:Class="X3DCcdInspector.Views.CoreTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CoreTileStyle}"
            Background="{Binding LoadColor}"
            Opacity="{Binding TileOpacity}">
        <Grid MinWidth="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Core index (small, top-left) -->
            <TextBlock Grid.Row="0"
                       Text="{Binding CoreLabel}"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="9" FontWeight="SemiBold"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Left"/>

            <!-- Load percentage (center, bold) + frequency below -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding LoadText}"
                           Style="{StaticResource BigNumber}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding FrequencyText}"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="9"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,-1,0,0"/>
            </StackPanel>

            <!-- Load bar (thin, bottom) -->
            <Border Grid.Row="2"
                    Height="3" CornerRadius="1.5"
                    Background="{StaticResource BorderSubtleBrush}"
                    Margin="0,3,0,0">
                <Border CornerRadius="1.5" HorizontalAlignment="Left"
                        Background="{StaticResource AccentGreenBrush}"
                        Opacity="0.7">
                    <Border.Width>
                        <MultiBinding>
                            <MultiBinding.Converter>
                                <local:LoadBarWidthConverter xmlns:local="clr-namespace:X3DCcdInspector.Converters"/>
                            </MultiBinding.Converter>
                            <Binding Path="LoadPercent"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}"/>
                        </MultiBinding>
                    </Border.Width>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
