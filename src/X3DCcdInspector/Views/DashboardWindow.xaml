<Window x:Class="X3DCcdInspector.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:X3DCcdInspector.Views"
        xmlns:converters="clr-namespace:X3DCcdInspector.Converters"
        Title="X3D CCD Inspector"
        Width="1100" Height="800"
        MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        Icon="pack://application:,,,/Resources/app.ico"
        AutomationProperties.Name="X3D CCD Inspector dashboard">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:DriverTooltipConverter x:Key="DriverTooltipConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- Row 0: System Status Panel                                    -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="12,12,12,0"
                AutomationProperties.Name="System status panel">
            <StackPanel>
                <!-- Line 1: CPU model + tier badge -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="{Binding SystemStatus.CpuModel}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource BadgeStyle}"
                            Background="{StaticResource AccentPurpleBrush}">
                        <TextBlock Text="{Binding SystemStatus.TierText}"
                                   Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Line 2: CCD info -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="CCD0:" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.Ccd0Info}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CCD1:" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.Ccd1Info}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Line 3: Status indicators (driver, state, Game Bar, GameMode) -->
                <WrapPanel Orientation="Horizontal">
                    <!-- AMD 3D V-Cache Driver -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Width="8" Height="8" Fill="{Binding SystemStatus.DriverServiceDot}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="AMD 3D V-Cache Driver:" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.DriverServiceStatus}" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Driver State -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Width="8" Height="8" Fill="{Binding SystemStatus.DriverStateDot}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Driver State:" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.DriverStateText}" FontSize="11"
                                   FontWeight="SemiBold" FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Xbox Game Bar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Width="8" Height="8" Fill="{Binding SystemStatus.GameBarDot}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xbox Game Bar:" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.GameBarStatus}" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- GameMode -->
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{Binding SystemStatus.GameModeDot}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="GameMode:" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding SystemStatus.GameModeText}" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 1: Active Game Panel (left) + CCD Heatmaps (right)        -->
        <!-- ============================================================ -->
        <Grid Grid.Row="1" Margin="8,8,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Active Game Panel -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="4,0"
                    AutomationProperties.Name="Active game panel">
                <Grid>
                    <!-- Idle state -->
                    <StackPanel Visibility="{Binding ActiveGame.IdleVisibility}"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="No game detected" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ActiveGame.DetectionStatusText}" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Active game state -->
                    <Grid Visibility="{Binding ActiveGame.GameActiveVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Game name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,3"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ActiveGame.GameName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,3"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Detected via -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Detected via:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActiveGame.DetectionMethod}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,2"/>

                        <!-- Process -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Process:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActiveGame.ProcessInfo}"
                                   FontSize="11" FontFamily="{StaticResource FontMono}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,2"/>

                        <!-- Running on -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Running on:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActiveGame.CcdDistribution}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,2"/>

                        <!-- Thread distribution -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Threads:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ActiveGame.ThreadCounts}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,2"/>

                        <!-- CCD Preference -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="CCD Preference:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ActiveGame.CcdPreference}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,0,2"/>

                        <!-- Driver Action -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Driver Action:"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ActiveGame.DriverAction}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- CCD Heatmap Panels -->
            <UniformGrid Grid.Column="1" Rows="1" Columns="2" Width="480">
                <views:CcdPanel DataContext="{Binding Ccd0Panel}" AutomationProperties.Name="Primary CCD panel"/>
                <views:CcdPanel DataContext="{Binding Ccd1Panel}" AutomationProperties.Name="Secondary CCD panel"/>
            </UniformGrid>
        </Grid>

        <!-- ============================================================ -->
        <!-- Row 2: Tabbed section (CCD Map + Game Library)                -->
        <!-- ============================================================ -->
        <TabControl Grid.Row="2" Margin="12,8,12,4" SelectedIndex="0"
                    Background="Transparent" BorderThickness="0"
                    AutomationProperties.Name="Dashboard tabs">
            <TabItem Header="CCD Map" AutomationProperties.Name="CCD Map tab">
                <Border Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="No processes detected"
                                   Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Visibility="{Binding CcdMap.EmptyVisibility}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CcdMap.ProcessView}">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Padding="6,3" Margin="0,2,0,1"
                                                        BorderThickness="2,0,0,0" BorderBrush="{StaticResource AccentBlueBrush}">
                                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                                        <Run Text="{Binding ItemCount, StringFormat='({0})', Mode=OneWay}"
                                                             Foreground="{StaticResource TextTertiaryBrush}"/>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4,3" Margin="8,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding ProcessName, Mode=OneWay}"/>
                                                    <Run Text="{Binding CountText, Mode=OneWay}"
                                                         Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"/>
                                                </TextBlock>
                                                <Border Grid.Column="1" CornerRadius="3" Padding="6,1" Margin="6,0"
                                                        Background="{Binding TypeBadgeColor}"
                                                        Visibility="{Binding IsGame, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="GAME" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding ExeName}"
                                                           FontFamily="{StaticResource FontMono}" FontSize="10"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Game Library tab -->
            <TabItem Header="Game Library" AutomationProperties.Name="Game Library tab">
                <Border Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{Binding GameLibrary.TotalCountText}"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   Margin="8,6,8,4"/>
                        <ListView ItemsSource="{Binding GameLibrary.Games}"
                                  Background="Transparent" BorderThickness="0"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  AutomationProperties.Name="Game library list">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="40" Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="36" CornerRadius="3"
                                                ClipToBounds="True" VerticalAlignment="Center">
                                            <Grid>
                                                <Border Background="{Binding SourceColor}" CornerRadius="3">
                                                    <TextBlock Text="{Binding InitialLetter, Mode=OneWay}"
                                                               FontSize="14" FontWeight="Bold" Foreground="White"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Opacity="0.6"/>
                                                </Border>
                                                <Image Source="{Binding ArtworkImage, Mode=OneWay}"
                                                       Stretch="UniformToFill"
                                                       Visibility="{Binding HasArtwork, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ExeName, Mode=OneWay}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <!-- CCD Preference dropdown (driver available) -->
                                        <ComboBox Grid.Column="2" Width="100" Height="24"
                                                  VerticalAlignment="Center" Margin="8,0,0,0"
                                                  FontSize="10"
                                                  SelectedValue="{Binding CcdPreference}"
                                                  SelectedValuePath="Tag"
                                                  Visibility="{Binding IsDriverAvailable, Converter={StaticResource BoolToVis}}"
                                                  ToolTip="Set CCD preference via AMD driver profile"
                                                  AutomationProperties.Name="CCD preference">
                                            <ComboBoxItem Tag="Auto" Content="Auto"/>
                                            <ComboBoxItem Tag="VCache" Content="V-Cache"/>
                                            <ComboBoxItem Tag="Frequency" Content="Frequency"/>
                                        </ComboBox>
                                        <!-- Fallback affinity pin dropdown (driver NOT available) -->
                                        <ComboBox Grid.Column="2" Width="100" Height="24"
                                                  VerticalAlignment="Center" Margin="8,0,0,0"
                                                  FontSize="10"
                                                  SelectedValue="{Binding FallbackCcdPin}"
                                                  SelectedValuePath="Tag"
                                                  Visibility="{Binding IsDriverAvailable, Converter={StaticResource InverseBoolToVis}}"
                                                  ToolTip="Pin game process to CCD via CPU affinity (fallback — driver not available)"
                                                  AutomationProperties.Name="Affinity pin CCD">
                                            <ComboBoxItem Tag="None" Content="None"/>
                                            <ComboBoxItem Tag="VCache" Content="V-Cache CCD"/>
                                            <ComboBoxItem Tag="Frequency" Content="Freq CCD"/>
                                        </ComboBox>
                                        <Border Grid.Column="3" Background="{Binding SourceColor}"
                                                CornerRadius="3" Padding="6,2" VerticalAlignment="Center"
                                                Margin="8,0,0,0">
                                            <TextBlock Text="{Binding SourceBadge, Mode=OneWay}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="2,0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ============================================================ -->
        <!-- Row 3: Activity Log (always visible)                          -->
        <!-- ============================================================ -->
        <DockPanel Grid.Row="3" Margin="12,0,12,4">
            <TextBlock DockPanel.Dock="Top" Text="Activity Log" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,4"/>
            <Border Style="{StaticResource CardStyle}" Padding="6">
                <ListBox x:Name="LogListBox"
                         ItemsSource="{Binding ActivityLog.Entries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         AlternationCount="2">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bg" CornerRadius="3" Padding="6,3" Margin="0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{StaticResource RowAltBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Opacity="{Binding Opacity}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="145"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ActionText}"
                                           Foreground="{Binding ActionColor}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           FontWeight="SemiBold" FontStyle="{Binding FontStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding DetailText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontStyle="{Binding FontStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- ============================================================ -->
        <!-- Row 4: Footer                                                 -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="4">
            <Rectangle Height="1" Margin="24,2,24,0"
                       Fill="{StaticResource FooterSeparatorBrush}"/>
            <DockPanel Margin="16,6,16,8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SubtleButtonStyle}"
                            Command="{Binding OpenAboutCommand}"
                            Content="About" FontSize="11" Padding="10,4"
                            AutomationProperties.Name="Open about window"/>
                    <Button Style="{StaticResource SubtleButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="Settings" FontSize="11" Padding="10,4" Margin="6,0,0,0"
                            AutomationProperties.Name="Open settings window"/>
                    <Button Style="{StaticResource SubtleButtonStyle}"
                            Command="{Binding ToggleOverlayCommand}"
                            Content="{Binding OverlayButtonText}"
                            FontSize="11" Padding="10,4" Margin="6,0,0,0"
                            AutomationProperties.Name="Toggle overlay visibility"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0" Opacity="0.7"
                            ToolTip="Running with administrator privileges"
                            AutomationProperties.Name="Administrator status indicator">
                    <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"
                               Margin="0,0,3,0"/>
                    <TextBlock Text="ADMIN" Foreground="{StaticResource AccentGreenBrush}"
                               FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding FooterText}" Style="{StaticResource HintText}"
                           VerticalAlignment="Center"/>
                <Button Command="{Binding ApplyUpdateCommand}"
                        Visibility="{Binding UpdateVisible, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource SubtleButtonStyle}"
                        Foreground="{StaticResource AccentGreenBrush}"
                        FontSize="10" FontWeight="SemiBold" Padding="8,3" Margin="8,0,0,0"
                        AutomationProperties.Name="Download and install update">
                    <TextBlock Text="{Binding UpdateText}"/>
                </Button>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
