<Window x:Class="X3DCcdInspector.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About X3D CCD Inspector"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App name + version -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="X3D CCD Inspector" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="VersionText" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
            <TextBlock Text="Visibility and control over CCD scheduling on AMD Ryzen processors"
                       FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Height="1" Margin="0,12,0,12"
                   Fill="{StaticResource BorderDefaultBrush}"/>

        <!-- Info section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="License:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" FontSize="12">
                    <Hyperlink x:Name="LicenseLink" Click="OnLinkClicked" Tag="https://www.gnu.org/licenses/old-licenses/gpl-2.0.en.html"
                               Foreground="{StaticResource AccentBlueBrush}">GPL v2</Hyperlink>
                </TextBlock>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Source:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" FontSize="12">
                    <Hyperlink x:Name="SourceLink" Click="OnLinkClicked" Tag="https://github.com/LordBlacksun/X3D-CCD-Optimizer"
                               Foreground="{StaticResource AccentBlueBrush}">github.com/LordBlacksun/X3D-CCD-Optimizer</Hyperlink>
                </TextBlock>
            </Grid>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Author:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="LordBlacksun" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
        </StackPanel>

        <!-- AI Disclosure -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}"
                CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="AI Disclosure" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Architecture, design, QA, and testing by the developer. Implementation assisted by Claude (Anthropic). Full source code is open for audit."
                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Credits -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Credits" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,2">
                <Run FontWeight="SemiBold">cocafe</Run>
                <Run Text="&#x2014; V-Cache driver registry interface discovery (vcache-tray)"/>
            </TextBlock>
            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,2">
                <Run FontWeight="SemiBold">JayzTwoCents</Run>
                <Run Text="&#x2014; CPPC=Driver BIOS setting research"/>
            </TextBlock>
        </StackPanel>

        <!-- Links -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock FontSize="11">
                <Hyperlink Click="OnLinkClicked" Tag="https://github.com/LordBlacksun/X3D-CCD-Optimizer"
                           Foreground="{StaticResource AccentBlueBrush}">GitHub</Hyperlink>
            </TextBlock>
            <TextBlock Text="  |  " FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
            <TextBlock FontSize="11">
                <Hyperlink Click="OnLinkClicked" Tag="https://github.com/LordBlacksun/X3D-CCD-Optimizer/wiki"
                           Foreground="{StaticResource AccentBlueBrush}">Wiki</Hyperlink>
            </TextBlock>
            <TextBlock Text="  |  " FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
            <TextBlock FontSize="11">
                <Hyperlink Click="OnLinkClicked" Tag="https://github.com/LordBlacksun/X3D-CCD-Optimizer/issues"
                           Foreground="{StaticResource AccentBlueBrush}">Report Issue</Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="6" Content="Close" IsDefault="True" IsCancel="True"
                Click="OnCloseClicked"
                HorizontalAlignment="Right" Padding="16,6"
                AutomationProperties.Name="Close about window"/>
    </Grid>
</Window>
